page {
  background: #f3f6fb;
  font-size: 34rpx;
  color: #1e2d3d;
}
.container { padding: 24rpx; }
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.title { font-size: 40rpx; font-weight: 700; margin-bottom: 16rpx; }
.subtitle { font-size: 30rpx; color: #456; margin-bottom: 12rpx; }
.big-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 34rpx;
  border-radius: 14rpx;
  margin-bottom: 16rpx;
  background: #0f4c81;
  color: #fff;
}
.disclaimer {
  font-size: 24rpx;
  line-height: 1.6;
  color: #5a6470;
  margin-top: 24rpx;
}
.tag { display:inline-block; padding: 4rpx 12rpx; border-radius: 999rpx; font-size:24rpx; margin-right:8rpx;}
.tag-green{ background:#e8f7ec; color:#1d7a36; }
.tag-yellow{ background:#fff6dc; color:#8b6b00; }
.tag-red{ background:#fde8e8; color:#a32020; }
